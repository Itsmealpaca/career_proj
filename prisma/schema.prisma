// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id              String   @id @default(uuid())
  source          String   @default("linkedin")
  sourceProfileId String?  @unique
  profileUrl      String?  @unique
  profileImageUrl String?
  fullName        String?
  headline        String?
  summary         String?
  locationText    String?
  industry        String?
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  rawJson         Json

  positions   CandidatePosition[]
  educations  CandidateEducation[]
  skills      CandidateSkill[]
}

model Company {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?  // 기업 개요
  logoUrl       String?
  products      String?  // 주요 제품/서비스 설명
  keywords      String?  // 연관 키워드 (쉼표 구분 문자열 등)
  fundingRound  String?  // 최근 투자 라운드
  totalFunding  Int?     // 누적 투자액 (단위는 자유롭게 사용)
  foundedAt     DateTime?
  headcount     Int?     // 임직원 수
  annualRevenue Int?     // 연 매출
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CandidatePosition {
  id            String    @id @default(uuid())
  candidateId   String
  companyName   String
  title         String
  employmentType String?
  startDate     DateTime?
  endDate       DateTime?
  isCurrent     Boolean   @default(false)
  description   String?
  locationText  String?
  sequenceIndex Int

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateEducation {
  id           String    @id @default(uuid())
  candidateId  String
  schoolName   String?
  degree       String?
  fieldOfStudy String?
  startDate    DateTime?
  endDate      DateTime?
  description  String?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateSkill {
  id              String @id @default(uuid())
  candidateId     String
  skillName       String
  normalizedSkill String

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model IngestRun {
  id         String    @id @default(uuid())
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  total      Int       @default(0)
  inserted   Int       @default(0)
  updated    Int       @default(0)
  failed     Int       @default(0)

  errors IngestError[]
}

model IngestError {
  id           String   @id @default(uuid())
  runId        String
  candidateKey String?
  errorMessage String
  rawFragment  Json?

  run IngestRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}
